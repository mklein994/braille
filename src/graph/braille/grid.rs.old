struct Point(usize, usize);

impl std::ops::Index<Point> for Grid<2, 4> {
    type Output = bool;

    fn index(&self, index: Point) -> &Self::Output {
        let Point(row, column) = index;

        let width = self.width;
        let height = self.height;
        todo!()
    }
}

