use super::Char;

#[derive(Debug)]
pub struct Grid<const N: usize, const M: usize> {
    inner: Vec<Vec<Vec<bool>>>,
    width: usize,
    height: usize,
}

impl<const N: usize, const M: usize> Grid<N, M> {
    pub fn new(width: usize, height: usize, values: &[bool]) -> Self {
        let columns: Vec<_> = values.chunks_exact(N).map(<[bool]>::to_vec).collect();
        let rows: Vec<_> = columns
            .chunks_exact(M)
            .map(<[std::vec::Vec<bool>]>::to_vec)
            .collect();
        Self {
            inner: rows,
            width,
            height,
        }
    }
}

